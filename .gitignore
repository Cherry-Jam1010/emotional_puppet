# =============================================================================
# Byte-compiled / optimized / DLL files
# =============================================================================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
.venv311/
.venv311_test/
venv/
.env

# =============================================================================
# Large data files (must be downloaded separately)
# =============================================================================

# SEED-VII raw EEG data (~170 GB) — download from the official source
SEED-VII_EEG_preprocessed/
SEED-VII.zip

# Kokoro TTS ONNX model (~100 MB) — download from kokoro-onnx releases
models/kokoro-v1.0.onnx
models/voices-v1.0.bin

# EmotiVoice model weights (downloaded separately via EmotiVoice setup)
third_party/EmotiVoice/models/
third_party/EmotiVoice/outputs/.mv/

# =============================================================================
# Generated / cached artifacts (regenerated on first run)
# =============================================================================

# EEG feature cache (~83 MB per full dataset)
artifacts/seed_vii/feature_cache/

# Trained model checkpoints (regenerated by training scripts)
artifacts/seed_vii/feature_window_run1/
artifacts/seed_vii/feature_window_run2/
artifacts/seed_vii/feature_window_run3_de/
artifacts/seed_vii/feature_training_run1/
artifacts/seed_vii/feature_training_run2/
artifacts/seed_vii/training_smoke/
artifacts/seed_vii/feature_window_cached_smoke/

# Runtime-generated audio
artifacts/orchestrator/audio/
output/

# Log files
artifacts/orchestrator_py311_stderr.log
artifacts/orchestrator_py311_stdout.log
artifacts/orchestrator_test_stderr.log
artifacts/orchestrator_test_stdout.log
artifacts/orchestrator/uvicorn.stderr.log
artifacts/orchestrator/uvicorn.stdout.log

# =============================================================================
# OS / IDE artifacts
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.log

# =============================================================================
# Credentials & secrets — NEVER commit
# =============================================================================
.env
*.pem
*.key
secrets/
